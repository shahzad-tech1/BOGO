<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.BOGO.BOGOUIController" styleClass="root">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="shell-header">
            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
            <Label text="BOGO" styleClass="header-text"/>
            <Label text="Admin Operations" styleClass="muted-text"/>
        </HBox>
    </top>
    <left>
        <VBox prefWidth="230" spacing="6" styleClass="nav-panel">
            <padding><Insets top="20" right="0" bottom="20" left="0"/></padding>
            <Button fx:id="btn_nav_dashboard" text="Dashboard" onAction="#loadAdminDashboard" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="btn_nav_analytics" text="Analytics" onAction="#loadAdminAnalytics" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="btn_nav_alerts" text="Resolve Alerts" onAction="#loadAdminAlerts" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="btn_nav_add_resource" text="Add Resource" onAction="#loadAdminAddResource" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="btn_nav_add_stops_routes" text="Add Stops / Routes" onAction="#loadAdminAddStopsRoutes" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="btn_nav_assign_route" text="Assign Route" onAction="#loadAdminAssignRoute" maxWidth="Infinity" styleClass="nav-button"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Logout" onAction="#goMain" maxWidth="Infinity" styleClass="logout-button"/>
        </VBox>
    </left>
    <center>
        <!-- TODO: Navigation Logic - Update style of active button and load respective FXML into content_area. -->
        <StackPane fx:id="content_area"/>
    </center>
</BorderPane>
