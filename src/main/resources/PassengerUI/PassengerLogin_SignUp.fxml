<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.BOGO.BOGOUIController" alignment="CENTER" styleClass="root">
    <VBox maxWidth="460" spacing="18" styleClass="neon-card">
        <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>
        <fx:define>
            <ToggleGroup fx:id="auth_group"/>
        </fx:define>
        <Label text="BOGO PASSENGER" styleClass="header-text"/>
        <HBox spacing="12">
            <ToggleButton fx:id="btn_show_login"  text="Login"   selected="true"
                          toggleGroup="$auth_group" onAction="#showLoginPane"
                          HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
            <ToggleButton fx:id="btn_show_signup" text="Sign Up"
                          toggleGroup="$auth_group" onAction="#showSignupPane"
                          HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        </HBox>

        <!-- ── LOGIN ──────────────────────────────────────────────── -->
        <VBox fx:id="pane_login" spacing="14">
            <TextField     fx:id="txt_login_email"    promptText="Email"    styleClass="neon-text-field"/>
            <PasswordField fx:id="txt_login_password" promptText="Password" styleClass="neon-text-field"/>
            <Button fx:id="btn_login" text="LOGIN" onAction="#loginPassenger"
                    maxWidth="Infinity" styleClass="button-green"/>
        </VBox>

        <!-- ── SIGN UP ─────────────────────────────────────────────── -->
        <VBox fx:id="pane_signup" visible="false" spacing="12">
            <TextField     fx:id="txt_fname"          promptText="First name"         styleClass="neon-text-field"/>
            <TextField     fx:id="txt_lname"          promptText="Last name"          styleClass="neon-text-field"/>
            <TextField     fx:id="txt_signup_email"   promptText="Email"              styleClass="neon-text-field"/>
            <TextField     fx:id="txt_signup_cnic"    promptText="CNIC (13 digits, no dashes)" styleClass="neon-text-field"/>
            <PasswordField fx:id="pf_password"        promptText="Password (8–20 chars, 1 uppercase, 1 digit)" styleClass="neon-text-field"/>
            <PasswordField fx:id="pf_confirm_password" promptText="Confirm password"  styleClass="neon-text-field"/>
            <Button fx:id="btn_signup" text="SIGN UP" onAction="#signupPassenger"
                    maxWidth="Infinity" styleClass="button-purple"/>
            <!-- Validation / error feedback -->
            <Label fx:id="lbl_signup_status" text="" wrapText="true"
                   style="-fx-text-fill:#ff4f4f; -fx-font-size:12px;"/>
        </VBox>

        <Button text="BACK" onAction="#goMain" maxWidth="Infinity" styleClass="button-purple"/>
    </VBox>
</VBox>
