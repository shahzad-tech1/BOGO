<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.BOGO.BOGOUIController" alignment="CENTER" styleClass="root">
    <VBox maxWidth="520" spacing="18" styleClass="neon-card">
        <padding><Insets top="28" right="28" bottom="28" left="28"/></padding>
        <fx:define>
            <ToggleGroup fx:id="priority_group"/>
            <ToggleGroup fx:id="type_group"/>
        </fx:define>
        <Label text="Send Alert" styleClass="header-text"/>
        <HBox spacing="12">
            <ToggleButton text="High Priority" selected="true" toggleGroup="$priority_group"/>
            <ToggleButton text="Low Priority" toggleGroup="$priority_group"/>
        </HBox>
        <HBox spacing="12">
            <ToggleButton text="Bus" selected="true" toggleGroup="$type_group"/>
            <ToggleButton text="Driver" toggleGroup="$type_group"/>
        </HBox>
        <TextArea fx:id="txt_alert_message" promptText="Describe the issue" prefRowCount="6" styleClass="neon-text-area"/>
        <Button fx:id="btn_send_message" text="SEND MESSAGE" maxWidth="Infinity"
                onAction="#handleDriverSendAlert" styleClass="button-purple"/>
        <Label fx:id="lbl_alert_status" text="" wrapText="true" styleClass="muted-text"/>
    </VBox>
</VBox>
