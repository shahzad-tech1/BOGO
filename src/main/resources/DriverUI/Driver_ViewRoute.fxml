<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.BOGO.BOGOUIController" styleClass="root">

    <!-- Driver-specific route map: only the driver's assigned route + their bus (DriverRouteMapController) -->
    <Pane fx:id="driver_route_map_pane"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          styleClass="map-placeholder"/>

    <!-- Header overlay -->
    <VBox AnchorPane.topAnchor="16" AnchorPane.leftAnchor="16" spacing="4">
        <Label text="My Route" styleClass="subheader-text"
               style="-fx-text-fill:#00f2ff; -fx-effect: dropshadow(gaussian,#00f2ff,8,0.6,0,0);"/>
        <Label text="Live simulation of your assigned route and bus position."
               styleClass="muted-text"/>
    </VBox>
</AnchorPane>
